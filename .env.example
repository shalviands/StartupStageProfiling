# Supabase — Public (safe in browser, prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — Secret (server only, NEVER prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenRouter — Secret (server only, NEVER prefix with NEXT_PUBLIC_)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# App URL (used in AI HTTP-Referer header)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
